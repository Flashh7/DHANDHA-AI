{
  "dataset_name": "Competition Density Proxy Data (JustDial Method)",
  "version": "1.0",
  "last_updated": "2024-12",
  "sources": [
    "JustDial.com (illustrative listings count)",
    "Google Maps business listings"
  ],
  "methodology": {
    "description": "JustDial listing counts serve as a proxy for local business/service density. Not a startup database but indicates competitive landscape.",
    "steps": [
      "Go to justdial.com",
      "Select target city",
      "Search target category",
      "Note total number of listings",
      "Repeat for 5-8 cities",
      "Normalize by population to get density per lakh"
    ],
    "competition_intensity_formula": "Competition Intensity = JustDial Listings in Category / City Population in Lakhs",
    "intensity_scale": {
      "above_500_per_lakh": "Hyper-competitive (Red zone)",
      "200_to_500_per_lakh": "Competitive (need differentiation)",
      "50_to_200_per_lakh": "Moderate (opportunity exists)",
      "below_50_per_lakh": "Under-served (blue ocean or no demand)"
    }
  },
