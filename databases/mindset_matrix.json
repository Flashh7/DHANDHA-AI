{
  "dataset_name": "Mindset Matrix - Indian Consumer Behavioral Scoring",
  "version": "1.0",
  "last_updated": "2024-12",
  "methodology": {
    "description": "Behavioral scores constructed from multiple proxy indicators",
    "scoring_scale": "1 to 10 (10 = highest / strongest)",
    "negative_factors": [
      "jugaad_presence",
      "relationship_dependency",
      "family_decision_influence"
    ],
    "proxy_sources": {
      "problem_pain_level": "Consumer complaint data (NCH, consumer forums), NSSO unmet needs data",
      "willingness_to_pay": "Per capita discretionary spending (NSSO), premium brand penetration (Nielsen/Kantar India)",
      "trust_speed": "Digital payment adoption rate (NPCI), e-commerce penetration (IBEF), new brand trial rates",
      "jugaad_presence": "Informal economy share (MSME unregistered ratio), cash transaction prevalence, grey market reports",
      "relationship_dependency": "Referral-driven purchase patterns, community commerce data, WhatsApp commerce usage",
      "family_decision_influence": "Household decision-making surveys (NFHS-5), joint family proportion (Census)"
    },
    "composite_formula": "CBS = (Problem_Pain × 0.15) + (WTP × 0.25) + (Trust_Speed × 0.25) − (Jugaad × 0.15) − (Relationship_Dep × 0.10) − (Family_Influence × 0.10) + 5 (base offset), normalized to 1-10"
  },
